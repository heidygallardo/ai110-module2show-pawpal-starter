classDiagram
    class Owner {
        -String name
        -String phoneNumber
        -String availability
        -Map preferences
        +addPet(pet) void
        +editPet(pet) void
        +removePet(pet) void
        +viewPets() List~Pet~
        +viewAllTasks() List~Task~
    }

    class Pet {
        -String name
        -String species
        -int age
        -List~String~ medicalConditions
        -Map preferences
        +addTask(task) void
        +editTask(task) void
        +removeTask(task) void
        +viewTasks() List~Task~
    }

    class Task {
        -String name
        -int duration
        -String time
        -int priority
        -String category
        -boolean isComplete
        +updateDetails(details) void
        +markComplete() void
    }

    class Scheduler {
        +generatePlan(pet, availableTime) Schedule
        +organizeByPriority(tasks) List~Task~
        +filterToConstraints(tasks, availableTime) List~Task~
        +explainPlan() String
    }

    Owner "1" *-- "0..*" Pet : owns
    Pet "1" *-- "0..*" Task : has
    Scheduler ..> Task : reads
    Scheduler ..> Pet : schedules for
